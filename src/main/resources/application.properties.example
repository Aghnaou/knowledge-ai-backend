server.port=8080
spring.application.name=knowledge-ai
spring.config.import=optional:file:.env[.properties]

spring.datasource.url=jdbc:postgresql://localhost:5432/knowledge_ai
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD

jwt.secret=YOUR_JWT_SECRET_MINIMUM_256_BITS
jwt.expiration=86400000
jwt.refresh-expiration=604800000

spring.ai.openai.api-key=${OPENAI_API_KEY}
spring.ai.openai.chat.options.model=gpt-4o-mini
spring.ai.openai.embedding.options.model=text-embedding-3-small

minio.endpoint=http://localhost:9000
minio.access-key=minioadmin
minio.secret-key=YOUR_MINIO_SECRET
minio.bucket-name=knowledge-ai-docs

spring.ai.vectorstore.pgvector.initialize-schema=true
spring.ai.vectorstore.pgvector.index-type=HNSW
spring.ai.vectorstore.pgvector.distance-type=COSINE_DISTANCE
spring.ai.vectorstore.pgvector.dimensions=1536

spring.servlet.multipart.max-file-size=50MB
spring.servlet.multipart.max-request-size=50MB

cors.allowed-origins=http://localhost:4200